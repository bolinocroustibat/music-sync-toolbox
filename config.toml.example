[local_files]
# Path to your music files directory
path = "/your/music/path/"

[discogs]
token = "your_token"
overwrite_year = true
overwrite_genre = true
embed_cover = true
overwrite_cover = true
rename_file = false

[spotify]
# OAuth credentials from Spotify Developer Dashboard
client_id = "your_client_id"
client_secret = "your_client_secret"
redirect_uri = "http://localhost:8888/callback"
# Optional: if not set, you'll be prompted to select a playlist
# playlist_id = "your_playlist_id"

[ytmusic]
# OAuth credentials from Google Cloud Console (TVs and Limited Input devices type)
client_id = "your_client_id"
client_secret = "your_client_secret"
# Optional: if not set, you'll be prompted to select a playlist
# playlist_id = "your_playlist_id"

[soulseek]
# Soulseek via slskd REST API: https://github.com/slskd/slskd — set API key in slskd config
host = "https://127.0.0.1:5031"
api_key = "your_slskd_api_key"
# Optional path prefix if slskd is behind a reverse proxy
# url_base = "/"
# verify_ssl = true
# request_timeout = 60
# Downloads go to slskd's configured download directory (align with local_files.path if desired)
